# CryptoFlow Backend Configuration
# ⚠️ EDUCATIONAL DEMO ONLY

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/cryptoflow
MONGODB_DBNAME=cryptoflow

# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cryptoflow

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-key-change-in-production

# CORS Settings (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Important Notice
# This backend is for educational purposes only.
# It is NOT a real cryptocurrency exchange or financial service.

